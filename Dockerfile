# clean base image containing only comfyui, comfy-cli and comfyui-manager
FROM runpod/worker-comfyui:5.8.4-base

# build-time tokens for gated downloads — never baked into final image.
# pass via: docker build --build-arg HF_TOKEN=$HF_TOKEN ...
ARG HF_TOKEN=""

# install custom nodes into comfyui
RUN git clone https://github.com/kijai/ComfyUI-KJNodes /comfyui/custom_nodes/ComfyUI-KJNodes && cd /comfyui/custom_nodes/ComfyUI-KJNodes && (git checkout 17cddd4959f00182c66954be2a7a32a6481d81be 2>/dev/null || (git fetch origin 17cddd4959f00182c66954be2a7a32a6481d81be --depth=1 && git checkout 17cddd4959f00182c66954be2a7a32a6481d81be) || echo "WARN: commit 17cddd4959f00182c66954be2a7a32a6481d81be unreachable in https://github.com/kijai/ComfyUI-KJNodes, falling back to default branch HEAD")
